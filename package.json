{
  "name": "hype-terminal",
  "version": "1.1.0",
  "description": "Una aplicación de terminal creada con Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "package:mac": "electron-builder build --mac",
    "package:win": "electron-builder build --windows",
    "package:linux": "electron-builder build --linux"
  },
  "packageManager": "pnpm@11.1.0",
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  },
  "author": "Carlos Mur",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.0.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.5.3"
  },
  "build": {
    "appId": "com.cmurestudillos.hype-terminal",
    "productName": "HYPE Terminal",
    "directories": {
      "output": "release/"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}
